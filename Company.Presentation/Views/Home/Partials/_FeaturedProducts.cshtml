@model Company.Presentation.Models.HomeViewModel


<section id="products" class="py-20 md:py-28 bg-surface">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12 md:mb-16">
            <div>
                <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-xs rounded-full mb-4">
                    محصولات متنوع
                </span>
                <h2 class="text-3xl md:text-5xl font-bold text-text mb-2">
                    نمونه محصولات
                </h2>
                @if (!string.IsNullOrEmpty(Model.ProductsDescription))
                {
                    <p class="text-text-secondary text-sm md:text-base">
                        @Model.ProductsDescription
                    </p>
                }
            </div>
            <div class="flex items-center gap-2">
                <button class="next-slide w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border transition-all duration-300 cursor-pointer border-surface-muted text-text-muted cursor-not-allowed">
                    <i class="fa-solid fa-arrow-right">
                    </i>
                </button>
                <button class="prev-slide w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border transition-all duration-300 cursor-pointer border-primary text-primary hover:bg-primary hover:text-white hover:shadow-lg hover:shadow-primary/30">
                    <i class="fa-solid fa-arrow-left">
                    </i>
                </button>
            </div>
        </div>
        <div class="swiper animate-fade-in ">
            <div class="swiper-wrapper">
                @foreach (var product in Model.FeaturedProducts)
                {
                    <div class="swiper-slide">
                        <div class="group relative flex-shrink-0 w-[280px] md:w-[320px] bg-white rounded-2xl overflow-hidden border border-surface-muted data-product-shop snap-start cursor-pointer"
                             style="animation-delay: 0ms; transform: translateY(0px); box-shadow: rgba(0, 0, 0, 0.04) 0px 2px 8px; transition: transform 0.4s, box-shadow 0.4s;">
                            <div class="relative aspect-square overflow-hidden bg-surface-alt">
                                <img alt="@product.Title"
                                     class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
                                     loading="lazy"
                                     src="@(product.MainImage ?? "/images/no-image.png")">
                                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                                </div>
                                <div class="absolute bottom-3 left-3 right-3 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
                                    <a asp-controller="Products" asp-action="Single" class="inline-flex items-center gap-1 px-3 py-1.5 bg-white/90 backdrop-blur-sm text-primary text-xs rounded-full font-medium">
                                        مشاهده جزئیات
                                        <i class="fa-solid fa-arrow-left-line"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="p-5 md:p-6">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="w-2 h-2 rounded-full bg-primary">
                                    </span>
                                    <span class="text-primary text-xs font-medium">product.bottles</span>
                                </div>
                                <h3 class="text-base md:text-lg font-bold text-text mb-2">
                                    @product.Title
                                </h3>
                                <p class="text-text-secondary text-xs leading-relaxed">
                                    @product.ShortDescription
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="flex justify-center mt-10 md:mt-14">
            <a href="/products" class="inline-flex items-center gap-2 px-8 py-3.5 bg-primary text-white text-sm font-medium rounded-full hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 transition-all duration-300 hover-lift cursor-pointer whitespace-nowrap">
                مشاهده همه محصولات
                <i class="fa-solid fa-arrow-left"></i>
            </a>
        </div>
    </div>
</section>