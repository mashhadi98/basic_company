@model Company.Presentation.Areas.Admin.Models.Roles.RoleCreateEditViewModel
@{
    ViewData["Title"] = string.IsNullOrEmpty(Model.Id) ? "ایجاد نقش" : "ویرایش نقش";
    ViewData["BreadcrumbParent"] = "نقش";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Roles", new { area = "Admin" });
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">@ViewData["Title"]</h3>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Roles" asp-action="Edit" method="post">
                    @if (!string.IsNullOrEmpty(Model.Id))
                    {
                        <input type="hidden" asp-for="Id" />
                    }
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">ذخیره</button>
                        <a class="btn btn-secondary" href="/Admin/Roles">بازگشت</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

