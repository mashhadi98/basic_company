@model Company.Presentation.Areas.Admin.Models.BlogCategoryViewModel

@{
    ViewData["Title"] = "ویرایش دسته‌بندی بلاگ";
    ViewData["BreadcrumbParent"] = "دسته‌بندی‌های بلاگ";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "BlogCategories", new { area = "Admin" });
}

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">ویرایش دسته‌بندی بلاگ</h3>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" asp-route-id="@ViewBag.CategoryId">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">عنوان *</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label">اسلاگ *</label>
                        <input asp-for="Slug" class="form-control" dir="ltr" placeholder="مثال: blog-category" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">توضیحات</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="SortOrder" class="form-label">ترتیب نمایش</label>
                            <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-center">
                            <div class="form-check mt-2">
                                <input asp-for="IsPublished" class="form-check-input" />
                                <label asp-for="IsPublished" class="form-check-label">منتشر شده</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SeoMetaTitle" class="form-label">عنوان SEO</label>
                        <input asp-for="SeoMetaTitle" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SeoMetaDescription" class="form-label">توضیحات SEO</label>
                        <textarea asp-for="SeoMetaDescription" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SeoKeywords" class="form-label">کلمات کلیدی SEO</label>
                        <input asp-for="SeoKeywords" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="CanonicalUrl" class="form-label">Canonical URL</label>
                        <input asp-for="CanonicalUrl" class="form-control" dir="ltr" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">به‌روزرسانی</button>
                        <a class="btn btn-secondary" href="/Admin/BlogCategories">بازگشت</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
