@model Company.Presentation.Models.HomeViewModel

<section id="order" class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 z-0"
         style="background-image: url(&quot;https://readdy.ai/api/search-image?query=Modern%20plastic%20manufacturing%20factory%20interior%20with%20warm%20ambient%20lighting%20industrial%20machinery%20producing%20plastic%20products%20clean%20organized%20production%20floor%20professional%20industrial%20photography%20warm%20pastel%20red%20amber%20tones%20wide%20angle%20cinematic%20view&amp;width=1920&amp;height=1080&amp;seq=21&amp;orientation=landscape&quot;); background-position: center 0px; background-size: cover; filter: brightness(0.35);">
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface z-[1]">
    </div>
    <div class="relative z-10 w-full px-4 md:px-8 lg:px-12 max-w-6xl mx-auto">
        <div class="text-center mb-12 md:mb-16">
            <span class="inline-block px-4 py-1 bg-white/10 text-white/80 text-xs rounded-full mb-4 border border-white/20">
                فرم ثبت سفارش
            </span>
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-3">
                ثبت سفارش
            </h2>
            @if (!string.IsNullOrEmpty(Model.OrderRequestDescription))
            {
                <p class="text-white/60 text-sm md:text-base max-w-lg mx-auto">
                    @Model.OrderRequestDescription
                </p>
            }
        </div>
        <div class="bg-white/95 backdrop-blur-xl rounded-3xl p-6 md:p-10 lg:p-12 border border-white/20 shadow-2xl animate-fade-in-up opacity-0-start"
             style="animation-fill-mode: forwards;">
            @if (!string.IsNullOrEmpty(Model.OrderSuccessMessage))
            {
                <div class="order-success-message">
                    <p>@Model.OrderSuccessMessage</p>
                </div>
            }
            else
            {
                <form asp-action="SubmitOrder" method="post">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-xs font-medium text-text mb-1.5" asp-for="OrderRequest.FullName"></label>
                            <input asp-for="OrderRequest.FullName" class="w-full px-4 py-3 border border-surface-muted rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300 hover:border-primary/30" />
                            <span asp-validation-for="OrderRequest.FullName"></span>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-text mb-1.5" asp-for="OrderRequest.PhoneNumber"></label>
                            <input asp-for="OrderRequest.PhoneNumber" class="w-full px-4 py-3 border border-surface-muted rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300 hover:border-primary/30" />
                            <span asp-validation-for="OrderRequest.PhoneNumber"></span>
                        </div>
                    </div>
                    <div class="grid gap-4 mb-4">
                        <div>
                            <label class="block text-xs font-medium text-text mb-1.5" asp-for="OrderRequest.Description"></label>
                            <textarea asp-for="OrderRequest.Description"
                                  placeholder="توضیحات اضافی درباره سفارش خود بنویسید..." rows="2"
                                  maxlength="500"
                                  class="w-full px-4 py-3 border border-surface-muted rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300 hover:border-primary/30 resize-none"
                                  style="min-height: 46px;"></textarea>
                        </div>
                    </div>
                    <div class="flex items-center justify-between">
                        <button type="submit"
                                class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-primary text-white text-sm font-medium rounded-xl hover:bg-primary-dark hover:shadow-xl hover:shadow-primary/30 transition-all duration-300 whitespace-nowrap hover-lift group cursor-pointer">
                            <i class="fa-solid fa-paper-plane-top transition-transform duration-300 group-hover:-translate-x-1"></i>
                            ارسال سفارش
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</section>