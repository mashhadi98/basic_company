@model Company.Presentation.Models.HomeViewModel
@{
    ViewData["Title"] = "تولید کننده محصولات پلاستیکی با کیفیت";
}

@await Html.PartialAsync("Partials/_Header", Model)
@await Html.PartialAsync("Partials/_Services", Model)
@await Html.PartialAsync("Partials/_AboutUs", Model)
@await Html.PartialAsync("Partials/_FeaturedProducts", Model)
@await Html.PartialAsync("Partials/_Customers", Model)
@await Html.PartialAsync("Partials/_LatestBlogs", Model)
@await Html.PartialAsync("Partials/_OrderRequest", Model)

@section Scripts {
    <script src="js/swiper-bundle.min.js">
    </script>
    <script>
        var products = new Swiper('#products .swiper', {
            slidesPerView: 3,
            loop: true,
            autoplay: {
                delay: 5000,
            },
            navigation: {
                nextEl: '#products .next-slide',
                prevEl: '#products.prev-slide',
            },

        });
    </script>
    <script>
        var clients = new Swiper('#clients .swiper', {
            slidesPerView: 4,
            loop: true,
            autoplay: {
                delay: 5000,
            },
            navigation: {
                nextEl: '#clients .next-slide',
                prevEl: '#clients .prev-slide',
            },

        });
    </script>
}