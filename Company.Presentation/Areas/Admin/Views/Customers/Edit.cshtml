@model Company.Presentation.Areas.Admin.Models.CustomerViewModel

@{
    ViewData["Title"] = "ویرایش مشتری";
    ViewData["BreadcrumbParent"] = "مشتریان";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Customers", new { area = "Admin" });
}

<div class="row">
    <div class="col-12">
        <form method="post" asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CompanyImage" />
            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">ویرایش مشتری</h3>
                        </div>
                        <div class="card-body">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="mb-3">
                                <label asp-for="CompanyName" class="form-label">نام شرکت *</label>
                                <input asp-for="CompanyName" class="form-control" />
                                <span asp-validation-for="CompanyName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">توضیح همکاری *</label>
                                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="SortOrder" class="form-label">ترتیب نمایش</label>
                                        <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6 d-flex align-items-center">
                                    <div class="form-check mb-3">
                                        <input asp-for="IsPublished" class="form-check-input" />
                                        <label asp-for="IsPublished" class="form-check-label">منتشر شده</label>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">ذخیره</button>
                                <a class="btn btn-secondary" href="/Admin/Customers">بازگشت</a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">تصویر شرکت</h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="CompanyImageFile" class="form-label">آپلود تصویر جدید</label>
                                <input asp-for="CompanyImageFile" id="companyImage" type="file" accept="image/*" class="form-control" />
                                <span asp-validation-for="CompanyImageFile" class="text-danger"></span>
                            </div>
                            <div class="border rounded p-2 text-center">
                                <img id="companyImagePreview" src="@(string.IsNullOrWhiteSpace(Model.CompanyImage) ? "" : Model.CompanyImage)" class="img-fluid" alt="پیش‌نمایش تصویر" style="max-height:240px;width:auto;display:@(string.IsNullOrWhiteSpace(Model.CompanyImage) ? "none" : "inline-block");" />
                                <div id="companyImagePlaceholder" class="text-muted" style="display:@(string.IsNullOrWhiteSpace(Model.CompanyImage) ? "block" : "none");">هنوز تصویری انتخاب نشده است.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('companyImage')?.addEventListener('change', function (event) {
            const input = event.target;
            const preview = document.getElementById('companyImagePreview');
            const placeholder = document.getElementById('companyImagePlaceholder');
            if (!input.files || input.files.length === 0) {
                preview.style.display = 'none';
                placeholder.style.display = 'block';
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = 'inline-block';
                placeholder.style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        });
    </script>
}
