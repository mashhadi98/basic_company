@model Company.Application.Features.CompanyFeatures.DTOs.CreateOrUpdateCompanyFeatureDto

@{
    ViewData["Title"] = "ویرایش ویژگی شرکت";
    ViewData["BreadcrumbParent"] = "ویژگی شرکت";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "CompanyFeatures", new { area = "Admin" });
}
<div class="row">
    <div class="col-12">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="row">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">ایجاد محصول</h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="Title">عنوان *</label>
                                <input asp-for="Title" class="form-control" placeholder="مثال: کیفیت بالا" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description">توضیحات *</label>
                                <textarea asp-for="Description" class="form-control" rows="3" placeholder="توضیح کوتاه برای نمایش در کارت‌ها"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Icon">آیکون *</label>
                                <input asp-for="Icon" class="form-control" placeholder="مثال: fas fa-star" />
                                <small class="form-text text-muted">کلاس آیکون FontAwesome یا BoxIcons را وارد کنید</small>
                                <span asp-validation-for="Icon" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="SortOrder">ترتیب نمایش</label>
                                <input asp-for="SortOrder" type="number" class="form-control" value="0" />
                                <span asp-validation-for="SortOrder" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <div class="custom-control custom-switch">
                                    <input asp-for="IsPublished" class="custom-control-input" />
                                    <label class="custom-control-label" asp-for="IsPublished">منتشر شود</label>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">ذخیره</button>
                                <a class="btn btn-secondary" href="/Admin/Products">بازگشت</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>