@model List<Company.Application.Features.Products.DTOs.ProductCategoryDto>

@{
    ViewData["Title"] = "دسته‌بندی محصولات";
}

<section class="content">
    <div class="container-fluid">
        <div class="card card-outline card-primary">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">لیست دسته‌بندی‌ها</h3>
                <a class="btn btn-primary ms-auto" href="/Admin/ProductCategories/Create">ایجاد دسته جدید</a>
            </div>
            <div class="card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>عنوان</th>
                            <th>اسلاگ</th>
                            <th>والد</th>
                            <th>اولویت</th>
                            <th>وضعیت انتشار</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4">دسته‌بندی‌ای ثبت نشده است.</td>
                            </tr>
                        }
                        else
                        {
                            var index = 1;
                            foreach (var category in Model)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@category.Title</td>
                                    <td>@category.Slug</td>
                                    <td>@(category.ParentCategoryTitle ?? "-")</td>
                                    <td>@category.SortOrder</td>
                                    <td>
                                        <span class="badge @(category.IsPublished ? "bg-success" : "bg-secondary")">
                                            @(category.IsPublished ? "منتشر شده" : "پیش‌نویس")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a class="btn btn-sm btn-outline-primary" href="/Admin/ProductCategories/Edit/@category.Id">ویرایش</a>
                                            <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('آیا از حذف این دسته‌بندی مطمئن هستید؟');">حذف</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
