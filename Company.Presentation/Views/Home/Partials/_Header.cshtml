@model Company.Presentation.Models.HomeViewModel


<section id="home" class="relative h-screen w-full overflow-hidden">
    <video autoplay loop playsinline class="absolute inset-0 w-full h-full object-cover">
        <source src="~/attachments/background.mp4" type="video/mp4">
    </video>
    <div class="absolute inset-0 bg-black/50">
    </div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4">
        <div class="animate-fade-in">
            <span class="inline-block px-4 py-1.5 mb-6 text-xs md:text-sm text-white/90 border border-white/40 rounded-full tracking-wide hover:border-primary hover:bg-primary/20 transition-all duration-300 cursor-default">
                شرکت بازرگانی شقایق توس
            </span>
        </div>
        <h1 class="animate-fade-in delay-200 text-3xl md:text-5xl lg:text-7xl font-bold text-white mb-4 leading-tight">
            نوآوری در تولید پلاستیک
        </h1>
        @foreach (var text in Model.Header.Texts.Where(x => !string.IsNullOrEmpty(x)))
        {
            <p class="animate-fade-in delay-300 text-sm md:text-lg lg:text-xl text-white/80 max-w-2xl mb-8 leading-relaxed">
                @text
            </p>
        }
    </div>
    <div class="absolute bottom-8 arrow-down -translate-x-1/2 z-10 animate-bounce">
        <a href="#services"
           class="flex flex-col items-center gap-1 text-white/60 hover:text-white transition-colors duration-300">
            <span class="text-xs">
                اسکرول کنید
            </span>
            <i class="fa-solid fa-arrow-down text-lg">
            </i>
        </a>
    </div>
</section>