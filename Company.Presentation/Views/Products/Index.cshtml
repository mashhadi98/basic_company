@model Company.Presentation.Models.ProductsIndexViewModel

@{
    ViewData["Title"] = "محصولات";
}

<section class="relative pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/products-hero.jpg');"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-surface-alt"></div>
    <div class="relative z-10 w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto text-center">
        <span class="inline-block px-4 py-1.5 bg-white/15 backdrop-blur-sm text-white text-xs rounded-full mb-5 border border-white/20">
            کاتالوگ محصولات
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 drop-shadow-sm">محصولات ما</h1>
        <p class="text-white/80 text-sm md:text-base max-w-xl mx-auto">
            مجموعه‌ای از محصولات پلاستیکی با کیفیت بالا و مشخصات کامل فنی.
        </p>
    </div>
</section>

<div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto mb-10 md:mb-14">
    <div class="flex flex-wrap gap-2 justify-center">
        <a href="@Url.Action("Index", "Products")" class="px-5 py-2.5 rounded-full text-sm whitespace-nowrap transition-all duration-300 cursor-pointer @(Model.SelectedCategoryId.HasValue ? "bg-white text-text-secondary border border-surface-muted hover:border-primary/30 hover:text-primary" : "bg-primary text-white shadow-lg shadow-primary/20")">
            همه محصولات
        </a>
        @foreach (var category in Model.Categories)
        {
            var selected = Model.SelectedCategoryId.HasValue && Model.SelectedCategoryId.Value == category.Id;
            <a href="@Url.Action("Index", "Products", new { categoryId = category.Id })" class="px-5 py-2.5 rounded-full text-sm whitespace-nowrap transition-all duration-300 cursor-pointer @(selected ? "bg-primary text-white shadow-lg shadow-primary/20" : "bg-white text-text-secondary border border-surface-muted hover:border-primary/30 hover:text-primary")">
                @category.Title
            </a>
        }
    </div>
</div>

<section class="pb-10 md:pb-14">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        @if (!Model.Products.Any())
        {
            <div class="rounded-3xl bg-white p-8 text-center border border-surface-muted">
                <h2 class="text-xl font-bold text-text mb-3">محصولی یافت نشد</h2>
                <p class="text-text-secondary text-sm">در حال حاضر هیچ محصول منتشر شده‌ای برای نمایش موجود نیست.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
                @foreach (var product in Model.Products)
                {
                    var category = Model.Categories.FirstOrDefault(c => c.Id == product.CategoryId);
                    <article class="group bg-white rounded-2xl overflow-hidden border border-surface-muted hover:border-primary/20 transition-all duration-500">
                        <a href="@Url.Action("Single", "Products", new { id = product.Id })" class="block">
                            <div class="relative aspect-square overflow-hidden bg-surface-muted">
                                <img alt="@product.Title" class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105" loading="lazy" src="@(string.IsNullOrWhiteSpace(product.MainImage) ? "/images/no-image.png" : product.MainImage)" />
                                @if (category is not null)
                                {
                                    <span class="absolute top-3 left-3 px-3 py-1 bg-white/90 backdrop-blur-sm text-primary text-xs rounded-full">@category.Title</span>
                                }
                            </div>
                            <div class="p-5 md:p-6">
                                <h3 class="text-base md:text-lg font-bold text-text mb-2 leading-snug group-hover:text-primary transition-colors duration-300">@product.Title</h3>
                                <p class="text-text-secondary text-sm leading-relaxed line-clamp-3 mb-4">@product.ShortDescription</p>
                                @if (product.Tags.Any())
                                {
                                    <div class="flex flex-wrap gap-2 mb-4">
                                        @foreach (var tag in product.Tags.Take(3))
                                        {
                                            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-surface-muted text-text-muted text-xs rounded-md">@tag.Name</span>
                                        }
                                    </div>
                                }
                                <div class="flex items-center justify-between pt-4 border-t border-surface-muted">
                                    <span class="text-text-muted text-xs flex items-center gap-1">مشاهده جزئیات</span>
                                    <span class="text-text-muted text-xs">@product.PublishStatus</span>
                                </div>
                            </div>
                        </a>
                    </article>
                }
            </div>
        }
    </div>
</section>

@if (Model.TotalPages > 1)
{
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto py-6">
        <div class="flex flex-wrap items-center justify-center gap-2">
            @if (Model.Page > 1)
            {
                <a href="@Url.Action("Index", "Products", new { categoryId = Model.SelectedCategoryId, page = Model.Page - 1 })" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-surface-muted bg-white text-text-secondary hover:bg-primary/10 transition">
                    قبلی
                </a>
            }

            @{ var startPage = Math.Max(1, Model.Page - 2); var endPage = Math.Min(Model.TotalPages, Model.Page + 2); }
            @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
            {
                <a href="@Url.Action("Index", "Products", new { categoryId = Model.SelectedCategoryId, page = pageNumber })"
                   class="inline-flex items-center justify-center w-10 h-10 rounded-full border text-sm transition @(pageNumber == Model.Page ? "bg-primary text-white border-primary" : "bg-white text-text-secondary border-surface-muted hover:bg-primary/10")">
                    @pageNumber
                </a>
            }

            @if (Model.Page < Model.TotalPages)
            {
                <a href="@Url.Action("Index", "Products", new { categoryId = Model.SelectedCategoryId, page = Model.Page + 1 })" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-surface-muted bg-white text-text-secondary hover:bg-primary/10 transition">
                    بعدی
                </a>
            }
        </div>
    </div>
}
