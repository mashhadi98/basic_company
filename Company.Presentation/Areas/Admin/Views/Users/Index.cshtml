@model IReadOnlyList<Company.Presentation.Areas.Admin.Models.Users.UserListItemViewModel>
@{
    ViewData["Title"] = "کاربران";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">لیست کاربران</h3>
                <a class="btn btn-primary" href="/Admin/Users/Create">ایجاد کاربر</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead>
                        <tr>
                            <th>نام کاربری</th>
                            <th>ایمیل</th>
                            <th>نام</th>
                            <th>شماره تماس</th>
                            <th>وضعیت</th>
                            <th style="width: 240px;">عملیات</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>@u.UserName</td>
                                <td>@u.Email</td>
                                <td>@u.FullName</td>
                                <td>@u.PhoneNumber</td>
                                <td>
                                    @if (u.EmailConfirmed)
                                    {
                                        <span class="badge bg-success">ایمیل تأیید</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">ایمیل تأیید نشده</span>
                                    }
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary" href="/Admin/Users/Edit/@u.Id">ویرایش</a>
                                    <a class="btn btn-sm btn-outline-secondary" href="/Admin/Users/Roles/@u.Id">نقش‌ها</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

