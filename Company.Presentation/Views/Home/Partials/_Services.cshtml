@model Company.Presentation.Models.HomeViewModel

<section id="services" class="py-20 md:py-28 bg-surface">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="text-center mb-14 md:mb-20">
            <span class="inline-block px-4 py-1 bg-primary/10 text-primary text-xs rounded-full mb-4">
                خدمات تخصصی
            </span>
            <h2 class="text-3xl md:text-5xl font-bold text-text mb-4">
                خدمات ما
            </h2>
            @if (!string.IsNullOrEmpty(Model.ServicesDescription))
            {
                <p class="text-text-secondary text-sm md:text-base max-w-lg mx-auto">
                    @Model.ServicesDescription
                </p>
            }
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            @foreach (var service in Model.Services)
            {
                <div class="group relative bg-surface-alt rounded-2xl p-8 md:p-10 border border-surface-muted transition-all duration-500 hover:border-primary/30 hover-lift hover-glow cursor-default animate-fade-in-up opacity-0-start"
                     style="animation-delay: 0ms; animation-fill-mode: forwards;">
                    <div class="w-16 h-16 md:w-20 md:h-20 flex items-center justify-center bg-primary/10 rounded-2xl mb-6 transition-all duration-500 group-hover:bg-primary group-hover:scale-110">
                        <i class="fa-solid @service.Icon text-2xl md:text-3xl text-primary transition-colors duration-500 group-hover:text-white">
                        </i>
                    </div>
                    <h3 class="text-lg md:text-xl font-bold text-text mb-3">
                        @service.Title
                    </h3>
                    <p class="text-text-secondary text-sm leading-relaxed">
                        @service.Description
                    </p>
                    <div class="absolute top-6 left-6 w-2 h-2 rounded-full bg-primary/20 group-hover:bg-primary transition-colors duration-500">
                    </div>
                </div>
            }
        </div>
    </div>
</section>
