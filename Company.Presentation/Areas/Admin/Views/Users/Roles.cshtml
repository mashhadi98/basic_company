@model Company.Presentation.Areas.Admin.Models.Users.UserRolesViewModel
@{
    ViewData["Title"] = "نقش‌های کاربر";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">نقش‌های کاربر: @Model.UserName</h3>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Users" asp-action="Roles" method="post">
                    <input type="hidden" name="userId" value="@Model.UserId" />

                    <div class="row">
                        @foreach (var role in Model.AllRoles)
                        {
                            var isChecked = Model.AssignedRoles.Contains(role.Name);
                            <div class="col-md-4 col-12 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="roles" value="@role.Name" id="role_@role.Name" @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="role_@role.Name">
                                        <strong>@role.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(role.Description))
                                        {
                                            <span class="text-muted">(@role.Description)</span>
                                        }
                                    </label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">ذخیره</button>
                        <a class="btn btn-secondary" href="/Admin/Users">بازگشت</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

