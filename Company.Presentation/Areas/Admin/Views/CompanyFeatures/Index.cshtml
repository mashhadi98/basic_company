@model List<Company.Application.Features.CompanyFeatures.DTOs.CompanyFeatureDto>

@{
    ViewData["Title"] = "مدیریت ویژگی‌های شرکت";
}

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">لیست محصولات</h3>
                <a class="btn btn-primary ms-auto" href="/Admin/Products/Create">ایجاد محصول</a>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle" id="featuresTable">
                            <thead>
                                <tr>
                                    <th>عنوان</th>
                                    <th>توضیحات</th>
                                    <th>آیکون</th>
                                    <th>ترتیب</th>
                                    <th>وضعیت</th>
                                    <th>تاریخ ایجاد</th>
                                    <th>عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var feature in Model)
                                {
                                    <tr data-id="@feature.Id">
                                        <td>@feature.Title</td>
                                        <td>@feature.Description</td>
                                        <td><i class="@feature.Icon"></i> @feature.Icon</td>
                                        <td>@feature.SortOrder</td>
                                        <td>
                                            @if (feature.IsPublished)
                                            {
                                                <span class="badge badge-success">منتشر شده</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">پیش‌نویس</span>
                                            }
                                        </td>
                                        <td>@feature.CreatedAt.ToShortDateString()</td>
                                        <td>
                                            <a href="@Url.Action("Edit", new { id = feature.Id })" class="btn btn-info btn-sm">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form method="post" action="@Url.Action("TogglePublish", new { id = feature.Id })" style="display: inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-warning btn-sm" title="@(feature.IsPublished ? "لغو انتشار" : "انتشار")">
                                                    <i class="fas fa-@(feature.IsPublished ? "eye-slash" : "eye")"></i>
                                                </button>
                                            </form>
                                            <form method="post" action="@Url.Action("Delete", new { id = feature.Id })" style="display: inline;" onsubmit="return confirm('آیا مطمئن هستید؟')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle"></i>
                        هیچ محصولی یافت نشد.
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#featuresTable tbody').sortable({
                update: function(event, ui) {
                    var items = [];
                    $('#featuresTable tbody tr').each(function(index) {
                        var id = $(this).data('id');
                        items.push({ Id: id, SortOrder: index });
                    });

                    $.ajax({
                        url: '@Url.Action("Reorder")',
                        type: 'POST',
                        data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(), items: items },
                        success: function(response) {
                            if (response.success) {
                                location.reload();
                            }
                        }
                    });
                }
            });
        });
    </script>
}