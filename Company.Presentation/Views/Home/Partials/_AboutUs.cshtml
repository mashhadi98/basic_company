@model Company.Presentation.Models.HomeViewModel


<section id="about" class="py-20 md:py-28 bg-surface-alt">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-16 items-center">
            <div>
                <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-xs rounded-full mb-4">
                    کارخانه تولیدی
                </span>
                <h2 class="text-3xl md:text-5xl font-bold text-text mb-6">
                    @Model.AboutUs.Page?.Title
                </h2>
                <p class="text-text-secondary text-sm md:text-base leading-relaxed mb-4">
                    @Model.AboutUs.Page?.Summary
                </p>

                <a href="/aboutus"
                   class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white text-sm rounded-full hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 transition-all duration-300 whitespace-nowrap hover-lift group animate-fade-in-up opacity-0-start">
                    بیشتر بدانید
                    <i class="fa-solid fa-arrow-left transition-transform duration-300 group-hover:-translate-x-1"></i>
                </a>
                <div class="grid grid-cols-2 gap-4 md:gap-6 mt-12">
                    @foreach (var stat in Model.AboutUs.Statistics)
                    {
                        <div class="bg-white rounded-xl p-5 md:p-6 border border-surface-muted hover-border-glow transition-all duration-300 animate-fade-in-up opacity-0-start"
                             style="animation-delay: 0ms; animation-fill-mode: forwards;">
                            <div class="text-2xl md:text-4xl font-bold text-primary mb-1">@stat.Value+</div>
                            <div class="text-text-muted text-xs md:text-sm">
                                @stat.Title
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="relative group">
                <div class="rounded-2xl overflow-hidden aspect-[4/5] relative">
                    <img alt="کارخانه"
                         class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
                         loading="lazy"
                         src="@(Model.AboutUs.ImageUrl ?? "/images/no-image.png")">
                    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-full text-xs font-medium text-text shadow-sm">
                        تهران، ایران
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4 md:p-6">
                        <p class="text-white text-sm font-medium">
                            تولید با تکنولوژی روز
                        </p>
                    </div>
                </div>
                <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-primary/10 rounded-2xl -z-10">
                </div>
                <div class="absolute -top-4 -right-4 w-16 h-16 bg-accent/20 rounded-2xl -z-10">
                </div>
            </div>
        </div>
    </div>
</section>