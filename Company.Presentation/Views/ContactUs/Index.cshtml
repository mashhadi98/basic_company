@{
    ViewData["Title"] = "تولید کننده محصولات پلاستیکی با کیفیت";
}
<section class="relative pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent">
    </div>
    <div class="relative z-10 w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto text-center">
        <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary text-xs rounded-full mb-5">
            پشتیبانی
            و مشاوره
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-text mb-4">تماس با ما</h1>
        <p class="text-text-secondary text-sm md:text-base max-w-xl mx-auto">
            برای هرگونه سوال، مشاوره یا ثبت
            سفارش با کارشناسان ما در تماس باشید
        </p>
    </div>
</section>
<section class="pb-10 md:pb-14">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
            <div class="bg-white rounded-2xl border border-surface-muted p-6 text-center hover-lift animate-fade-in-up opacity-0-start"
                 style="animation-delay: 0ms; animation-fill-mode: forwards;">
                <div class="w-14 h-14 flex items-center justify-center bg-primary/10 rounded-2xl mx-auto mb-4">
                    <i class="ri-map-pin-2-line text-2xl text-primary">
                    </i>
                </div>
                <h3 class="font-bold text-text text-sm mb-2">آدرس کارخانه</h3>
                <p class="text-text-secondary text-xs leading-relaxed">
                    تهران، جاده مخصوص کرج، کیلومتر ۱۸،
                    شهرک صنعتی پلاستیک
                </p>
            </div>
            <div class="bg-white rounded-2xl border border-surface-muted p-6 text-center hover-lift animate-fade-in-up opacity-0-start"
                 style="animation-delay: 100ms; animation-fill-mode: forwards;">
                <div class="w-14 h-14 flex items-center justify-center bg-primary/10 rounded-2xl mx-auto mb-4">
                    <i class="ri-phone-line text-2xl text-primary">
                    </i>
                </div>
                <h3 class="font-bold text-text text-sm mb-2">تلفن تماس</h3>
                <p class="text-text-secondary text-xs leading-relaxed">۰۲۱-۴۴۹۸۷۶۵۴</p>
            </div>
            <div class="bg-white rounded-2xl border border-surface-muted p-6 text-center hover-lift animate-fade-in-up opacity-0-start"
                 style="animation-delay: 200ms; animation-fill-mode: forwards;">
                <div class="w-14 h-14 flex items-center justify-center bg-primary/10 rounded-2xl mx-auto mb-4">
                    <i class="ri-time-line text-2xl text-primary">
                    </i>
                </div>
                <h3 class="font-bold text-text text-sm mb-2">ساعت کاری</h3>
                <p class="text-text-secondary text-xs leading-relaxed">شنبه تا چهارشنبه: ۸ صبح تا ۵ عصر</p>
            </div>
        </div>
    </div>
</section>
<section class="pb-16 md:pb-24">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
            <div class="bg-white rounded-2xl border border-surface-muted p-6 md:p-8">
                <h2 class="text-xl font-bold text-text mb-2 flex items-center gap-2">
                    <i class="ri-send-plane-line text-primary">
                    </i>ارسال پیام
                </h2>
                <p class="text-text-secondary text-xs mb-6">
                    فرم زیر را پر کنید، کارشناسان ما در اولین فرصت
                    پاسخگوی شما خواهند بود
                </p>
                <form data-readdy-form="contact-form">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-xs font-medium text-text mb-1.5">
                                نام و نام
                                خانوادگی
                            </label>
                            <input placeholder="نام خود را وارد کنید" required=""
                                   class="w-full px-4 py-3 border border-surface-muted rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300 hover:border-primary/30"
                                   type="text" value="" name="name">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-text mb-1.5">شماره تلفن</label>
                            <input placeholder="۰۹۱۲۳۴۵۶۷۸۹" required=""
                                   class="w-full px-4 py-3 border border-surface-muted rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300 hover:border-primary/30"
                                   type="tel" value="" name="phone">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="block text-xs font-medium text-text mb-1.5">موضوع</label>
                        <select name="subject"
                                class="w-full px-4 py-3 border border-surface-muted rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300 hover:border-primary/30 bg-white">
                            <option value="">موضوع پیام را انتخاب کنید</option>
                            <option value="order">ثبت سفارش</option>
                            <option value="consult">مشاوره فنی</option>
                            <option value="support">پشتیبانی</option>
                            <option value="other">سایر</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="block text-xs font-medium text-text mb-1.5">متن پیام</label>
                        <textarea name="message" placeholder="پیام خود را بنویسید..." rows="5"
                                  maxlength="500" required=""
                                  class="w-full px-4 py-3 border border-surface-muted rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300 hover:border-primary/30 resize-none">
</textarea>
                        <span class="text-text-muted text-xs mt-1 block text-left">0/500</span>
                    </div>
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-white text-sm font-medium rounded-xl hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 transition-all duration-300 whitespace-nowrap hover-lift cursor-pointer">
                        <i class="ri-send-plane-line">
                        </i>ارسال پیام
                    </button>
                </form>
            </div>
            <div class="flex flex-col gap-6">
                <div class="bg-white rounded-2xl border border-surface-muted overflow-hidden flex-1 min-h-[300px]">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3239.5!2d51.3!3d35.7!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzXCsDQyJzAwLjAiTiA1McKwMTgnMDAuMCJF!5e0!3m2!1sen!2sir!4v1"
                            width="100%" height="100%" allowfullscreen="" loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade" title="موقعیت کارخانه"
                            class="w-full h-full" style="border: 0px; min-height: 320px;">
                    </iframe>
                </div>
                <div class="bg-white rounded-2xl border border-surface-muted p-6">
                    <h3 class="font-bold text-text text-sm mb-4">شبکه&zwnj;های اجتماعی</h3>
                    <div class="flex items-center gap-3">
                        <a href="#" rel="nofollow"
                           class="w-12 h-12 flex items-center justify-center rounded-full bg-surface-muted text-text-secondary hover:bg-primary hover:text-white transition-all duration-300 hover-lift"
                           title="اینستاگرام">
                            <i class="ri-instagram-line text-lg">
                            </i>
                        </a>
                        <a href="#" rel="nofollow"
                           class="w-12 h-12 flex items-center justify-center rounded-full bg-surface-muted text-text-secondary hover:bg-primary hover:text-white transition-all duration-300 hover-lift"
                           title="تلگرام">
                            <i class="ri-telegram-line text-lg">
                            </i>
                        </a>
                        <a href="#" rel="nofollow"
                           class="w-12 h-12 flex items-center justify-center rounded-full bg-surface-muted text-text-secondary hover:bg-primary hover:text-white transition-all duration-300 hover-lift"
                           title="واتساپ">
                            <i class="ri-whatsapp-line text-lg">
                            </i>
                        </a>
                        <a href="#" rel="nofollow"
                           class="w-12 h-12 flex items-center justify-center rounded-full bg-surface-muted text-text-secondary hover:bg-primary hover:text-white transition-all duration-300 hover-lift"
                           title="لینکدین">
                            <i class="ri-linkedin-line text-lg">
                            </i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>