@model CreateOrUpdateProductDto
@using Company.Application.Features.Products.DTOs

@{
    var productId = (Guid)ViewBag.ProductId;
    ViewData["Title"] = "ویرایش محصول";
    ViewData["BreadcrumbParent"] = "محصولات";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Products", new { area = "Admin" });
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">ویرایش محصول</h3>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Edit" asp-route-id="@productId">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">عنوان محصول *</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label">Slug (URL Slug) *</label>
                        <input asp-for="Slug" class="form-control" dir="ltr" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="CategoryId" class="form-label">دسته‌بندی</label>
                                <select asp-for="CategoryId" class="form-control">
                                    <option value="">-- انتخاب دسته‌بندی --</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var category in ViewBag.Categories)
                                        {
                                            <option value="@category.Id">@category.Title</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="SortOrder" class="form-label">ترتیب نمایش</label>
                                <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ShortDescription" class="form-label">توضیح کوتاه *</label>
                        <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="ShortDescription" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullDescription" class="form-label">توضیح کامل *</label>
                        <textarea asp-for="FullDescription" class="form-control" rows="6"></textarea>
                        <span asp-validation-for="FullDescription" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                <input asp-for="IsFeatured" class="form-check-input" />
                                <label asp-for="IsFeatured" class="form-check-label">محصول برجسته</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PublishStatus" class="form-label">وضعیت انتشار</label>
                                <select asp-for="PublishStatus" class="form-control">
                                    <option value="Draft">پیش‌نویس</option>
                                    <option value="Published">منتشر شده</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">ذخیره</button>
                        <a class="btn btn-secondary" href="/Admin/Products">بازگشت</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}