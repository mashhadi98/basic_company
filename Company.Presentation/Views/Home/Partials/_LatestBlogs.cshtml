@model Company.Presentation.Models.HomeViewModel


<section id="blog" class="py-20 md:py-28 bg-surface">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12 md:mb-16">
            <div>
                <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-xs rounded-full mb-4">
                    مجله تخصصی
                </span>
                <h2 class="text-3xl md:text-5xl font-bold text-text mb-2">
                    آخرین مقالات
                </h2>
                @if (!string.IsNullOrEmpty(Model.BlogDescription))
                {
                    <p class="text-text-secondary text-sm md:text-base">
                        @Model.BlogDescription
                    </p>
                }
            </div>
            <button class="inline-flex items-center gap-1 text-primary text-sm hover:text-primary-dark transition-colors duration-300 whitespace-nowrap group cursor-pointer">
                ادامه مطلب
                <i class="fa-solid fa-arrow-left transition-transform duration-300 group-hover:-translate-x-1"></i>
            </button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
            @foreach (var post in Model.LatestBlogPosts)
            {

                <article class="group bg-white rounded-2xl overflow-hidden border border-surface-muted cursor-pointer transition-all duration-500 hover:border-primary/20 hover-lift animate-fade-in-up opacity-0-start"
                         style="animation-delay: 0ms; animation-fill-mode: forwards;">
                    <div class="relative aspect-[2/1] overflow-hidden">
                        <img alt="@post.Title"
                             class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
                             loading="lazy"
                             src="@(post.FeaturedImage ?? "/images/no-image.png")">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                        </div>
                    </div>
                    <div class="p-5 md:p-6">
                        <span class="text-text-muted text-xs">@post.PublishedDate.ToString("yyyy/MM/dd")</span>
                        <h3 class="text-base md:text-lg font-bold text-text mt-2 mb-3 leading-snug group-hover:text-primary transition-colors duration-300">
                            @post.Title
                        </h3>
                        <p class="text-text-secondary text-xs md:text-sm leading-relaxed line-clamp-3">
                            @post.Summary
                        </p>
                        <a asp-controller="Blogs" asp-action="Single" class="mt-4 pt-4 border-t border-surface-muted flex items-center gap-2 text-primary text-xs font-medium opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
                            <span>
                                ادامه مطلب
                            </span>
                            <i class="fa-solid fa-arrow-left-line"></i>
                        </a>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
