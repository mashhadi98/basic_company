@model Company.Presentation.Areas.Admin.Models.Roles.RolePermissionsViewModel
@{
    ViewData["Title"] = "مجوزهای نقش";
    ViewData["BreadcrumbParent"] = "نقش";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Roles", new { area = "Admin" });
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">مجوزهای نقش: @Model.RoleName</h3>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Roles" asp-action="Permissions" method="post">
                    <input type="hidden" name="roleId" value="@Model.RoleId" />

                    @{
                        var groups = Model.AllPermissions
                            .GroupBy(p => p.Group)
                            .OrderBy(g => g.Key)
                            .ToList();
                    }

                    @foreach (var grp in groups)
                    {
                        <div class="mb-3">
                            <h5 class="mb-2">@grp.Key</h5>
                            <div class="row">
                                @foreach (var p in grp.OrderBy(x => x.Name))
                                {
                                    var checkedAttr = Model.AssignedPermissionNames.Contains(p.Name);
                                    <div class="col-md-4 col-12 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="permissionNames" value="@p.Name" id="perm_@p.Id" @(checkedAttr ? "checked" : "") />
                                            <label class="form-check-label" for="perm_@p.Id">
                                                <strong>@p.DisplayName</strong>
                                                <span class="text-muted">(@p.Name)</span>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">ذخیره</button>
                        <a class="btn btn-secondary" href="/Admin/Roles">بازگشت</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

