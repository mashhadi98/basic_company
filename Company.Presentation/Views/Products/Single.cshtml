@model Company.Application.Features.Products.DTOs.ProductDto

@using Company.Application.Features.Products.DTOs

@{
    ViewData["Title"] = Model.Title;
    var mainImage = string.IsNullOrWhiteSpace(Model.MainImage) ? "/images/no-image.png" : Model.MainImage;
}

<div class="pt-24 md:pt-28 pb-6 w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
    <nav class="flex items-center gap-2 text-xs text-text-muted">
        <a href="@Url.Action("Index", "Home")" class="hover:text-primary transition-colors">خانه</a>
        <i class="ri-arrow-left-s-line"></i>
        <a href="@Url.Action("Index", "Products")" class="hover:text-primary transition-colors">محصولات</a>
        <i class="ri-arrow-left-s-line"></i>
        <span class="text-text truncate max-w-[200px]">@Model.Title</span>
    </nav>
</div>

<section class="pb-10 md:pb-14">
    <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
            <div class="space-y-4">
                <div class="relative aspect-square rounded-2xl overflow-hidden border border-surface-muted bg-white">
                    <img alt="@Model.Title" class="w-full h-full object-cover object-center" src="@mainImage" />
                </div>
                @if (Model.GalleryImages.Any())
                {
                    <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
                        @foreach (var image in Model.GalleryImages.Take(4))
                        {
                            <div class="relative w-20 h-20 md:w-24 md:h-24 rounded-xl overflow-hidden border border-surface-muted">
                                <img alt="@image.AltText" class="w-full h-full object-cover object-center" src="@(string.IsNullOrWhiteSpace(image.ImageUrl) ? "/images/no-image.png" : image.ImageUrl)" />
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="flex flex-col">
                @if (!string.IsNullOrWhiteSpace(ViewBag.CategoryTitle as string))
                {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 text-primary text-xs rounded-full w-fit mb-4">@ViewBag.CategoryTitle</span>
                }
                <h1 class="text-2xl md:text-3xl font-bold text-text mb-4 leading-snug">@Model.Title</h1>
                <p class="text-text-secondary text-sm md:text-base leading-relaxed mb-6">@Model.ShortDescription</p>
                @if (Model.Attributes.Any())
                {
                    <div class="bg-white rounded-2xl border border-surface-muted p-5 md:p-6 mb-6">
                        <h3 class="text-sm font-bold text-text mb-4 flex items-center gap-2"><i class="ri-list-check-2 text-primary"></i>مشخصات محصول</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            @foreach (var attribute in Model.Attributes)
                            {
                                <div class="flex items-start gap-3 p-3 bg-surface-muted/50 rounded-xl">
                                    <div class="w-8 h-8 flex items-center justify-center bg-primary/10 text-primary rounded-lg shrink-0">
                                        <i class="ri-check-line text-sm"></i>
                                    </div>
                                    <div>
                                        <span class="text-text-muted text-xs block">@(attribute.Key)</span>
                                        <span class="text-text text-sm font-medium">@(attribute.Value)</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                <div class="flex flex-wrap gap-3 mt-auto">
                    <a href="@Url.Action("Index", "Products")" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-text border border-surface-muted text-sm font-medium rounded-xl hover:border-primary/30 hover:text-primary transition-all duration-300 whitespace-nowrap">
                        <i class="ri-arrow-go-back-line"></i>بازگشت به محصولات
                    </a>
                    @if (!string.IsNullOrWhiteSpace(Model.CatalogPdfFile))
                    {
                        <a href="@Model.CatalogPdfFile" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white text-sm font-medium rounded-xl hover:bg-primary-dark transition-all duration-300 whitespace-nowrap">دانلود کاتالوگ</a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.FullDescription))
{
    <section class="pb-10 md:pb-14">
        <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
            <div class="bg-white rounded-2xl border border-surface-muted p-6 md:p-10">
                <h2 class="text-xl md:text-2xl font-bold text-text mb-6 flex items-center gap-2"><i class="ri-file-text-line text-primary"></i>توضیحات کامل</h2>
                <div class="space-y-4 text-text-secondary text-sm md:text-base leading-relaxed">
                    @Html.Raw(Model.FullDescription.Replace("\n", "<br />"))
                </div>
            </div>
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.VideoUrl) || Model.Tags.Any())
{
    <section class="pb-20 md:pb-28">
        <div class="w-full px-4 md:px-8 lg:px-12 max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                @if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
                {
                    <div class="bg-white rounded-2xl border border-surface-muted p-6">
                        <h2 class="text-lg font-bold text-text mb-4">ویدیو معرفی محصول</h2>
                        <a href="@Model.VideoUrl" target="_blank" class="inline-flex items-center gap-2 text-primary hover:text-primary-dark">مشاهده ویدیو <i class="ri-video-line"></i></a>
                    </div>
                }
                @if (Model.Tags.Any())
                {
                    <div class="bg-white rounded-2xl border border-surface-muted p-6">
                        <h2 class="text-lg font-bold text-text mb-4">برچسب‌ها</h2>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var tag in Model.Tags)
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-2 bg-surface-muted rounded-full text-sm text-text-muted">@tag.Name</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}
